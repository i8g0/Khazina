# Application
APP_NAME=Khazina API
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database — DATABASE_URL is required (no default)
DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true

# Authentication (Sprint 4.2) — JWT_SECRET_KEY is required (no default)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI (Sprint 5.1) — Ollama connectivity; values are environment-specific
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL is required — set to the model name chosen by the operator/deployment
OLLAMA_MODEL=
AI_TIMEOUT=30
DEFAULT_PROMPT_LANGUAGE=ar

# Server host/port are configured via the uvicorn command (see README)
