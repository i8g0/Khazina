# Application
APP_NAME=Khazina API
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database
# Docker: DATABASE_URL is set by docker-compose. Local: use localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/khazina
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true

# Server host/port are configured via the uvicorn command (see README)
