# Application
APP_NAME=Khazina API
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# Database — DATABASE_URL is required (no default)
DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true

# Authentication (Sprint 4.2) — JWT_SECRET_KEY is required (no default)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI (Sprint 5.1 / Phase 10) — provider selection and inference settings
AI_PROVIDER=ollama

# Ollama (when AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL is required when AI_PROVIDER=ollama
OLLAMA_MODEL=

# Cloud (when AI_PROVIDER=cloud) — OpenAI-compatible API
# CLOUD_AI_BASE_URL=https://api.openai.com/v1
# CLOUD_AI_MODEL=
# CLOUD_AI_API_KEY=

AI_TIMEOUT=30
AI_TEMPERATURE=0.7
# Run independent LLM tasks concurrently (defaults true when AI_PROVIDER=cloud)
# AI_PARALLEL_TASKS=true
DEFAULT_PROMPT_LANGUAGE=ar

# AI Benchmark Framework (Sprint 5.5) — benchmark-only settings
# BENCHMARK_PROFILE=quick
# BENCHMARK_TIMEOUT=600
# BENCHMARK_THINKING_MODE=disabled

# Storage (Sprint 6.2) — Bronze file persistence
BRONZE_STORAGE_ROOT=./data/bronze
MAX_UPLOAD_SIZE_BYTES=10485760