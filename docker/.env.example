# Docker Compose environment (development defaults only)
# Copy to docker/.env to override: cp docker/.env.example docker/.env

# PostgreSQL
POSTGRES_USER=khazina
POSTGRES_PASSWORD=khazina
POSTGRES_DB=khazina
POSTGRES_PORT=5432

# Services
BACKEND_PORT=8000
FRONTEND_PORT=3000
# Hackathon demo — OpenAI only (Ollama service optional / not used by backend)
AI_PROVIDER=cloud
CLOUD_AI_BASE_URL=https://api.openai.com/v1
CLOUD_AI_MODEL=gpt-4o-mini
CLOUD_AI_API_KEY=
AI_TIMEOUT=180
AI_PARALLEL_TASKS=true
LOG_LEVEL=INFO
