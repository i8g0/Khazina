# Docker Compose environment (development defaults only)
# Copy to docker/.env to override: cp docker/.env.example docker/.env

# PostgreSQL
POSTGRES_USER=khazina
POSTGRES_PASSWORD=khazina
POSTGRES_DB=khazina
POSTGRES_PORT=5432

# Services
BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_PORT=11434
OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL is required — set after the operator selects a model for this deployment
OLLAMA_MODEL=
AI_TIMEOUT=30
LOG_LEVEL=INFO
